# ─── Text-to-LEGO Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# ─── LLM API (Stage 1) ────────────────────────────────────────────────────────
# At least one is required. "auto" mode uses whichever key is present.
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
OPENAI_API_KEY=sk-...your-key-here...          # optional, fallback

# ─── Rebrickable (Parts database) ─────────────────────────────────────────────
# Free tier: 1 req/sec. Get key at https://rebrickable.com/api/
REBRICKABLE_API_KEY=your-key-here

# ─── BrickLink (Pricing - optional) ───────────────────────────────────────────
# Required only for live pricing. Needs static IP registration.
# Get keys at: https://www.bricklink.com/v3/api.page
BRICKLINK_CONSUMER_KEY=your-consumer-key
BRICKLINK_CONSUMER_SECRET=your-consumer-secret
BRICKLINK_ACCESS_TOKEN=your-access-token
BRICKLINK_ACCESS_TOKEN_SECRET=your-access-token-secret
